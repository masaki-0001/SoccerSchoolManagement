@model SoccerSchoolManagement.Models.Student

@{
    ViewData["Title"] = "生徒詳細";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-1">生徒詳細</h1>
        <p class="text-muted mb-0">@Model.Name（@Model.Kana）</p>
    </div>

    <div class="d-flex flex-wrap gap-2">
        <a asp-action="Edit"
           asp-route-id="@Model.Id"
           class="btn btn-primary">編集</a>
        <a asp-action="Delete"
           asp-route-id="@Model.Id"
           class="btn btn-outline-danger">削除</a>
        <a asp-action="Index"
           class="btn btn-secondary">一覧へ戻る</a>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header">基本情報</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">氏名</dt>
                    <dd class="col-sm-8">@Model.Name</dd>

                    <dt class="col-sm-4">ふりがな</dt>
                    <dd class="col-sm-8">@Model.Kana</dd>

                    <dt class="col-sm-4">生年月日</dt>
                    <dd class="col-sm-8">@Model.BirthDate.ToString("yyyy年M月d日")</dd>

                    <dt class="col-sm-4">学年</dt>
                    <dd class="col-sm-8">@Model.Grade</dd>

                    <dt class="col-sm-4">性別</dt>
                    <dd class="col-sm-8">@Model.Gender</dd>

                    <dt class="col-sm-4">背番号</dt>
                    <dd class="col-sm-8">
                        @(Model.JerseyNumber.HasValue
                            ? Model.JerseyNumber.Value.ToString()
                            : "未登録")
                    </dd>

                    <dt class="col-sm-4">入会日</dt>
                    <dd class="col-sm-8">@Model.JoinedAt.ToString("yyyy年M月d日")</dd>

                    <dt class="col-sm-4">在籍状況</dt>
                    <dd class="col-sm-8">@Model.Status</dd>

                    <dt class="col-sm-4">退会日</dt>
                    <dd class="col-sm-8">
                        @(Model.WithdrawnAt.HasValue
                            ? Model.WithdrawnAt.Value.ToString("yyyy年M月d日")
                            : "未登録")
                    </dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header">保護者情報</div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">保護者氏名</dt>
                    <dd class="col-sm-8">@Model.GuardianName</dd>

                    <dt class="col-sm-4">続柄</dt>
                    <dd class="col-sm-8">@Model.GuardianRelationship</dd>

                    <dt class="col-sm-4">電話番号</dt>
                    <dd class="col-sm-8">@Model.GuardianPhone</dd>

                    <dt class="col-sm-4">メールアドレス</dt>
                    <dd class="col-sm-8">
                        @(string.IsNullOrWhiteSpace(Model.GuardianEmail)
                            ? "未登録"
                            : Model.GuardianEmail)
                    </dd>
                </dl>
            </div>
        </div>
    </div>
</div>

<div class="card mt-4">
    <div class="card-header">備考</div>
    <div class="card-body">
        @if (string.IsNullOrWhiteSpace(Model.Note))
        {
            <p class="text-muted mb-0">備考は登録されていません。</p>
        }
        else
        {
            <p class="mb-0">@Model.Note</p>
        }
    </div>
</div>

@model List<SoccerSchoolManagement.Models.Student>

@{
    ViewData["Title"] = "生徒一覧";
}

<h1>生徒一覧</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">
        新規登録
    </a>
</p>

@if (Model.Count == 0)
{
    <p>登録されている生徒はいません。</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>氏名</th>
                <th>ふりがな</th>
                <th>学年</th>
                <th>在籍状況</th>
                <th>保護者電話番号</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var student in Model)
            {
                <tr>
                    <td>@student.Name</td>
                    <td>@student.Kana</td>
                    <td>@student.Grade</td>
                    <td>@student.Status</td>
                    <td>@student.GuardianPhone</td>
                </tr>
            }
        </tbody>
    </table>
}
@model SoccerSchoolManagement.ViewModels.Home.DashboardViewModel

@{
    ViewData["Title"] = "ダッシュボード";
}

<div class="mb-4">
    <h1>ダッシュボード</h1>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h6 text-muted">
                    在籍生徒数
                </h2>

                <p class="fs-2 fw-bold mb-0">
                    @Model.ActiveStudentCount 人
                </p>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h6 text-muted">
                    未払い件数
                </h2>

                <p class="fs-2 fw-bold mb-2">
                    @Model.UnpaidCount 件
                </p>

                <a asp-controller="Payments"
                   asp-action="Unpaid"
                   class="btn btn-outline-danger btn-sm">
                    未払い一覧を確認
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h6 text-muted">
                    未払い合計額
                </h2>

                <p class="fs-2 fw-bold mb-0">
                    @Model.UnpaidTotalAmount.ToString("N0") 円
                </p>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card h-100">
            <div class="card-header">
                今日の練習予定
            </div>

            <div class="card-body">
                @if (Model.TodayLessons.Count == 0)
                {
                    <p class="text-muted mb-0">
                        今日の練習予定はありません。
                    </p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-striped align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>時間</th>
                                    <th>クラス</th>
                                    <th>会場</th>
                                    <th>担当者</th>
                                    <th>開催状況</th>
                                    <th>操作</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var lesson in Model.TodayLessons)
                                {
                                    <tr>
                                        <td>
                                            @lesson.StartTime.ToString(@"hh\:mm")
                                            ～
                                            @lesson.EndTime.ToString(@"hh\:mm")
                                        </td>

                                        <td>
                                            @lesson.ClassName
                                        </td>

                                        <td>
                                            @lesson.VenueName
                                        </td>

                                        <td>
                                            @lesson.CoachName
                                        </td>

                                        <td>
                                            @lesson.Status
                                        </td>

                                        <td>
                                            @if (lesson.Status == "中止" || lesson.Status == "休講")
                                            {
                                                <span class="text-muted">
                                                    出欠登録対象外
                                                </span>
                                            }
                                            else
                                            {
                                                <a asp-controller="Attendances"
                                                   asp-action="Edit"
                                                   asp-route-lessonId="@lesson.Id"
                                                   class="btn btn-outline-primary btn-sm">
                                                    出欠登録
                                                </a>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header">
                主要メニュー
            </div>

            <div class="card-body">
                <div class="d-grid gap-3">
                    <a asp-controller="Students"
                       asp-action="Index"
                       class="btn btn-primary">
                        生徒管理
                    </a>

                    <a asp-controller="Classes"
                       asp-action="Index"
                       class="btn btn-primary">
                        クラス管理
                    </a>

                    <a asp-controller="Lessons"
                       asp-action="Index"
                       class="btn btn-primary">
                        練習予定
                    </a>

                    <a asp-controller="Payments"
                       asp-action="Index"
                       class="btn btn-primary">
                        月謝管理
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
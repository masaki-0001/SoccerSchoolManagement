@model SoccerSchoolManagement.ViewModels.Payments.PaymentUnpaidViewModel

@{
    ViewData["Title"] = "未払い一覧";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>未払い一覧</h1>

    <a asp-controller="Payments"
       asp-action="Index"
       class="btn btn-outline-secondary">
        月謝管理へ戻る
    </a>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="border rounded p-3">
            <div class="text-muted mb-1">
                未払い件数
            </div>

            <div class="fs-3 fw-bold">
                @Model.UnpaidCount 件
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="border rounded p-3">
            <div class="text-muted mb-1">
                未払い合計額
            </div>

            <div class="fs-3 fw-bold">
                @Model.TotalAmount.ToString("N0") 円
            </div>
        </div>
    </div>
</div>

@if (Model.Payments.Count == 0)
{
    <div class="alert alert-success">
        未払いの月謝はありません。
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-bordered table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>対象年月</th>
                    <th>生徒名</th>
                    <th>請求額</th>
                    <th>備考</th>
                    <th>月謝管理</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var payment in Model.Payments)
                {
                    <tr>
                        <td>
                            @payment.TargetYear 年
                            @payment.TargetMonth 月
                        </td>

                        <td>
                            @payment.Student.Name
                        </td>

                        <td>
                            @payment.Amount.ToString("N0") 円
                        </td>

                        <td>
                            @if (string.IsNullOrWhiteSpace(payment.Note))
                            {
                                <span>-</span>
                            }
                            else
                            {
                                @payment.Note
                            }
                        </td>

                        <td>
                            <a asp-controller="Payments"
                               asp-action="Index"
                               asp-route-year="@payment.TargetYear"
                               asp-route-month="@payment.TargetMonth"
                               class="btn btn-sm btn-outline-primary">
                                対象月を開く
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
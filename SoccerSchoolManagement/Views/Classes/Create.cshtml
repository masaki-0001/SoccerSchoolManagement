@using SoccerSchoolManagement.ViewModels.Classes
@model SoccerClassCreateViewModel

@{
    ViewData["Title"] = "クラス登録";
}

<h1>クラス登録</h1>

<div class="row">
    <div class="col-md-8">
        <form asp-action="Create"
              method="post">

            <div asp-validation-summary="ModelOnly"
                 class="text-danger"></div>

            <h2 class="h4 mt-3">基本情報</h2>

            <div class="mb-3">
                <label asp-for="Name"
                       class="form-label">
                    クラス名
                </label>

                <input asp-for="Name"
                       class="form-control" />

                <span asp-validation-for="Name"
                      class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="TargetGrade"
                       class="form-label">
                    対象学年
                </label>

                <input asp-for="TargetGrade"
                       class="form-control"
                       placeholder="例：1年生～3年生" />

                <span asp-validation-for="TargetGrade"
                      class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="DayOfWeek"
                       class="form-label">
                    曜日
                </label>

                <select asp-for="DayOfWeek"
                        class="form-select">

                    <option value="">
                        選択してください
                    </option>

                    @foreach (var day in SoccerClassFormOptions.DaysOfWeek)
                    {
                        <option value="@day">
                            @day
                        </option>
                    }
                </select>

                <span asp-validation-for="DayOfWeek"
                      class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="StartTime"
                           class="form-label">
                        開始時刻
                    </label>

                    <input asp-for="StartTime"
                           type="time"
                           class="form-control" />

                    <span asp-validation-for="StartTime"
                          class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="EndTime"
                           class="form-label">
                        終了時刻
                    </label>

                    <input asp-for="EndTime"
                           type="time"
                           class="form-control" />

                    <span asp-validation-for="EndTime"
                          class="text-danger"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="VenueName"
                       class="form-label">
                    会場名
                </label>

                <input asp-for="VenueName"
                       class="form-control" />

                <span asp-validation-for="VenueName"
                      class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="CoachName"
                       class="form-label">
                    担当者名
                </label>

                <input asp-for="CoachName"
                       class="form-control" />

                <span asp-validation-for="CoachName"
                      class="text-danger"></span>
            </div>

            <h2 class="h4 mt-4">その他</h2>

            <div class="mb-3">
                <label asp-for="Note"
                       class="form-label">
                    備考
                </label>

                <textarea asp-for="Note"
                          class="form-control"
                          rows="5"></textarea>

                <span asp-validation-for="Note"
                      class="text-danger"></span>
            </div>

            <div class="mt-4 d-flex gap-2">
                <button type="submit"
                        class="btn btn-primary">
                    登録
                </button>

                <a asp-action="Index"
                   class="btn btn-secondary">
                    一覧へ戻る
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
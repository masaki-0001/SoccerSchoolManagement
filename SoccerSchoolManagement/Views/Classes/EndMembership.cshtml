@model SoccerSchoolManagement.ViewModels.Classes.StudentClassEndViewModel

@{
    ViewData["Title"] = "所属終了";
}

<h1>所属終了</h1>

<p class="text-muted">
    生徒のクラス所属に終了日を設定します。
</p>

<div class="row">
    <div class="col-md-8">
        <div class="card mb-4">
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">
                        生徒名
                    </dt>

                    <dd class="col-sm-8">
                        @Model.StudentName
                    </dd>

                    <dt class="col-sm-4">
                        クラス名
                    </dt>

                    <dd class="col-sm-8">
                        @Model.ClassName
                    </dd>

                    <dt class="col-sm-4">
                        所属開始日
                    </dt>

                    <dd class="col-sm-8">
                        @Model.StartDate.ToString("yyyy年M月d日")
                    </dd>
                </dl>
            </div>
        </div>

        <form asp-action="EndMembership"
              asp-route-id="@Model.StudentClassId"
              method="post">

            <input asp-for="StudentClassId"
                   type="hidden" />

            <input asp-for="ClassId"
                   type="hidden" />

            <div asp-validation-summary="ModelOnly"
                 class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="EndDate"
                       class="form-label">
                    所属終了日
                </label>

                <input asp-for="EndDate"
                       type="date"
                       class="form-control" />

                <span asp-validation-for="EndDate"
                      class="text-danger"></span>
            </div>

            <div class="alert alert-info">
                所属終了後もデータは削除されず、
                過去の所属履歴として残ります。
            </div>

            <div class="d-flex gap-2">
                <button type="submit"
                        class="btn btn-primary">
                    所属を終了
                </button>

                <a asp-action="Details"
                   asp-route-id="@Model.ClassId"
                   class="btn btn-secondary">
                    キャンセル
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
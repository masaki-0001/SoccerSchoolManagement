<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="utf-8" />
    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>
        @ViewData["Title"] = サッカー教室業務管理
    </title>

    <script type="importmap"></script>

    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="~/css/site.css"
          asp-append-version="true" />

    <link rel="stylesheet"
          href="~/SoccerSchoolManagement.styles.css"
          asp-append-version="true" />
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-sm
            navbar-toggleable-sm
            navbar-light
            bg-white
            border-bottom
            box-shadow
            mb-3">

            <div class="container-fluid">
                <a class="navbar-brand"
                   asp-controller="Home"
                   asp-action="Index">
                    サッカー教室業務管理
                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent"
                        aria-expanded="false"
                        aria-label="Toggle navigation">

                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse
                    collapse
                    d-sm-inline-flex
                    justify-content-between">

                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark"
                               asp-controller="Home"
                               asp-action="Index">
                                ホーム
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark"
                               asp-controller="Students"
                               asp-action="Index">
                                生徒管理
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark"
                               asp-controller="Classes"
                               asp-action="Index">
                                クラス管理
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark"
                               asp-controller="Lessons"
                               asp-action="Index">
                                練習予定
                            </a>

                        <li class="nav-item">
                            <a class="nav-link text-dark"
                               asp-controller="Payments"
                               asp-action="Index">
                                月謝管理
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; サッカー教室業務管理
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js">
    </script>

    <script src="~/js/site.js"
            asp-append-version="true">
    </script>

    @await RenderSectionAsync(
        "Scripts",
        required: false)
</body>
</html>